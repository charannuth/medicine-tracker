#!/bin/sh
# Strip Cursor's co-author trailer from commit messages.
# This repo uses core.hooksPath=.githooks

set -eu

MSG_FILE="${1:-}"
if [ -z "$MSG_FILE" ] || [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

# Remove exact trailer line(s) and any immediate surrounding extra blank lines at EOF.
TMP="$(mktemp)"

awk '
  # Drop Cursor co-author trailer lines
  $0 ~ /^Co-authored-by: Cursor <cursoragent@cursor\.com>$/ { next }
  { print }
' "$MSG_FILE" > "$TMP"

# Trim trailing blank lines (git is fine either way, but keeps messages clean)
perl -0777 -pe 's/\n+\z/\n/s' "$TMP" > "$MSG_FILE"
rm -f "$TMP"

exit 0

